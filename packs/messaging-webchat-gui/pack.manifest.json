      "id": "messaging-provider-webchat-gui",
      "version": "0.4.38",
      "world": "root:component/root",
      "supports": [
        "messaging"
      ],
      "profiles": {
        "default": "default",
        "supported": [
          "default"
        ]
      },
      "capabilities": {
        "wasi": {
          "random": false,
          "clocks": false
        },
        "host": {}
      },
      "wasm": "components/messaging-provider-webchat-gui/component.wasm"
    }
  ],
  "config_schema": {
    "provider_config": {
      "format": "json",
      "path": "schemas/messaging/webchat-gui/public.config.schema.json"
    }
  },
  "extensions": {
    "greentic.ext.capabilities.v1": {
      "kind": "greentic.ext.capabilities.v1",
      "version": "0.4.38",
      "inline": {
        "offers": [
          {
            "cap_id": "greentic.cap.messaging.provider.v1",
            "offer_id": "messaging-webchat-gui-v1",
            "priority": 100,
            "provider": {
              "component_ref": "messaging-provider-webchat-gui",
              "op": "messaging.configure"
            },
            "requires_setup": true,
            "setup": {
              "qa_ref": "setup.yaml"
            },
            "version": "0.4.38"
          }
        ],
        "schema_version": 1
      }
    },
    "greentic.messaging.validators.v1": {
      "kind": "greentic.messaging.validators.v1",
      "version": "0.4.38",
      "inline": {
        "validators": [
          {
            "component_ref": "oci://ghcr.io/greenticai/validators/messaging:0.4.19",
            "id": "greentic.validators.messaging",
            "world": "greentic:pack-validate/pack-validator@0.1.0"
          }
        ]
      }
    },
    "greentic.provider-extension.v1": {
      "kind": "greentic.provider-extension.v1",
      "version": "0.4.38",
      "inline": {
        "providers": [
          {
            "provider_type": "messaging.webchat-gui",
            "capabilities": [
              "messaging"
            ],
            "ops": [
              "send",
              "ingest",
              "qa-spec",
              "apply-answers",
              "i18n-keys"
            ],
            "config_schema_ref": "schemas/messaging/webchat-gui/public.config.schema.json",
            "runtime": {
              "component_ref": "messaging-provider-webchat-gui",
              "export": "schema-core-api",
              "world": "greentic:provider/schema-core@1.0.0"
            }
          }
        ]
      }
    },
    "greentic.static-routes.v1": {
      "kind": "greentic.static-routes.v1",
      "version": "0.4.38",
      "inline": {
        "routes": [
          {
            "id": "webchat-gui",
            "index_file": "index.html",
            "public_path": "/v1/web/webchat/{tenant}",
            "scope": {
              "team": false,
              "tenant": true
            },
            "source_root": "assets/webchat-gui",
            "spa_fallback": "index.html"
          }
        ],
        "version": 1
      }
    },
    "messaging.provider_flow_hints": {
      "kind": "messaging.provider_flow_hints",
      "version": "0.4.38",
      "inline": {
        "messaging.webchat-gui": {
          "default": "default",
          "diagnostics": "diagnostics",
          "remove": "remove",
          "setup_default": "setup_default",
          "update": "update",
          "verify_webhooks": "verify_webhooks"
        }
      }
    },
    "messaging.provider_ingress.v1": {
      "kind": "messaging.provider_ingress.v1",
      "version": "0.4.38",
      "inline": {
        "capabilities": {
          "content_types": [
            "application/json"
          ],
          "supports_webhook_validation": false
        },
        "component_ref": "messaging-provider-webchat-gui",
        "export": "ingest-http",
        "world": "greentic:provider/schema-core@1.0.0"
      }
    },
    "messaging.provider_routes.v1": {
      "kind": "messaging.provider_routes.v1",
      "version": "0.4.38",
      "inline": {
        "backend_base_path": "/v1/messaging/webchat/{tenant}",
        "provider_type": "messaging.webchat-gui",
        "routes": [
          {
            "id": "directline-token",
            "kind": "backend",
            "path": "/v1/messaging/webchat/{tenant}/token"
          },
          {
            "id": "directline-api",
            "kind": "backend",
            "path": "/v1/messaging/webchat/{tenant}/v3/directline/{*path}"
          }
        ]
      }
    }
  },
  "secret_requirements": [],
  "flows": [

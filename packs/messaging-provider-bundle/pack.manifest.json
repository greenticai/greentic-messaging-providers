  "extensions": {
    "greentic.provider-extension.v1": {
      "kind": "greentic.provider-extension.v1",
      "version": "0.4.38",
      "inline": {
        "providers": [
          {
            "provider_type": "messaging.provider.bundle",
            "capabilities": [
              "messaging"
            ],
            "ops": [
              "noop"
            ],
            "config_schema_ref": "schemas/messaging/bundle/public.config.schema.json",
            "state_schema_ref": "",
            "runtime": {
              "component_ref": "messaging-provider-dummy",
              "export": "schema-core-api",
              "world": "greentic:provider/schema-core@1.0.0"
            },
            "docs_ref": ""
          }
        ]
      }
    }
  },
  "secret_requirements": [
    {
      "name": "DUMMY_API_TOKEN",
      "scope": "tenant",
      "description": "Dummy provider token (redacted in describe/config metadata)."
    }
  ],
  "capabilities_cache": [
    {
      "component": "templates",
      "version": "v1",
      "path": "components/templates-capabilities_v1.json"

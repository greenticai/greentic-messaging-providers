{
  "name": "messaging-provider-bundle",
  "publisher": "Greentic",
  "version": "0.4.38",
  "kind": "application",
  "components": [
    "templates",
    "messaging-provider-dummy",
    "ai.greentic.component-provision",
    "ai.greentic.component-qa"
  ],
  "component_sources": [
    {
      "id": "templates",
      "version": "0.4.38",
      "world": "greentic:component/component@0.5.0",
      "supports": [
        "messaging"
      ],
      "profiles": {
        "default": "stateless",
        "supported": [
          "stateless"
        ]
      },
      "capabilities": {
        "wasi": {
          "random": false,
          "clocks": false
        },
        "host": {}
      },
      "wasm": "components/templates/component.wasm"
    },
    {
      "id": "messaging-provider-dummy",
      "version": "0.4.38",
      "world": "greentic:provider/schema-core@1.0.0",
      "supports": [
        "messaging"
      ],
      "profiles": {
        "default": "default",
        "supported": [
          "default"
        ]
      },
      "capabilities": {
        "wasi": {
          "random": false,
          "clocks": false
        },
        "host": {}
      },
      "wasm": "components/messaging-provider-dummy/component.wasm"
    },
    {
      "id": "ai.greentic.component-provision",
      "version": "0.4.38",
      "world": "greentic:component/component@0.5.0",
      "supports": [
        "messaging"
      ],
      "profiles": {
        "default": "stateless",
        "supported": [
          "stateless"
        ]
      },
      "capabilities": {
        "host": {
          "state": {
            "delete": false,
            "read": false,
            "write": true
          },
          "telemetry": {
            "scope": "node"
          }
        },
        "wasi": {
          "clocks": false,
          "filesystem": {
            "mode": "none",
            "mounts": []
          },
          "random": false
        }
      },
      "wasm": "components/provision/provision.wasm"
    },
    {
      "id": "ai.greentic.component-qa",
      "version": "0.4.38",
      "world": "greentic:component/component@0.5.0",
      "supports": [
        "messaging"
      ],
      "profiles": {
        "default": "stateless",
        "supported": [
          "stateless"
        ]
      },
      "capabilities": {
        "host": {
          "messaging": {
            "inbound": true,
            "outbound": true
          },
          "qa": {
            "process": true
          },
          "secrets": {
            "required": []
          },
          "telemetry": {
            "scope": "node"
          }
        },
        "wasi": {
          "clocks": true,
          "filesystem": {
            "mode": "none",
            "mounts": []
          },
          "random": true
        }
      },
      "wasm": "components/qa/qa.wasm"
    }

  "config_schema": {
    "provider_config": {
      "format": "json",
      "path": "schemas/messaging/slack/public.config.schema.json"
    }
  },
  "description": "Provider-core Slack messaging pack (chat.postMessage).",
  "extensions": {
    "greentic.ext.capabilities.v1": {
      "kind": "greentic.ext.capabilities.v1",
      "version": "0.4.36",
      "inline": {
        "schema_version": 1,
        "offers": [
          {
            "offer_id": "messaging-slack-v1",
            "cap_id": "greentic.cap.messaging.provider.v1",
            "version": "0.4.36",
            "provider": {
              "component_ref": "messaging-provider-slack",
              "op": "messaging.configure"
            },
            "priority": 100,
            "requires_setup": true,
            "setup": {
              "qa_ref": "setup.yaml"
            }
          }
        ]
      }
    },
    "greentic.messaging.validators.v1": {
      "kind": "greentic.messaging.validators.v1",
      "version": "0.4.36",
      "inline": {
        "validators": [
          {
            "component_ref": "oci://ghcr.io/greenticai/validators/messaging:0.4.19",
            "id": "greentic.validators.messaging",
            "world": "greentic:pack-validate/pack-validator@0.1.0"
          }
        ]
      }
    },
    "greentic.provider-extension.v1": {
      "kind": "greentic.provider-extension.v1",
      "version": "0.4.36",
      "inline": {
        "providers": [
          {
            "provider_type": "messaging.slack.api",
            "capabilities": [
              "messaging"
            ],
            "ops": [
              "send",
              "reply",
              "qa-spec",
              "apply-answers",
              "i18n-keys"
            ],
            "config_schema_ref": "schemas/messaging/slack/public.config.schema.json",
            "runtime": {
              "component_ref": "messaging-provider-slack",
              "export": "schema-core-api",
              "world": "greentic:provider/schema-core@1.0.0"
            }
          }
        ]
      }
    },
    "messaging.oauth.v1": {
      "kind": "messaging.oauth.v1",
      "version": "0.4.36",
      "inline": {
        "auth_type": "oauth2",
        "authorize_url": "https://slack.com/oauth/v2/authorize",
        "provider_id": "slack",
        "redirect_path": "/oauth/callback/slack",
        "scopes": [
          "chat:write",
          "channels:read",
          "channels:history"
        ],
        "secret_keys": [
          "SLACK_BOT_TOKEN"
        ],
        "token_url": "https://slack.com/api/oauth.v2.access"
      }
    },
    "messaging.provider_flow_hints": {
      "kind": "messaging.provider_flow_hints",
      "version": "0.4.36",
      "inline": {
        "messaging.slack.api": {
          "default": "default",
          "diagnostics": "diagnostics",
          "remove": "remove",
          "rotate_credentials": "rotate_credentials",
          "setup_default": "setup_default",
          "update": "update",
          "verify_webhooks": "verify_webhooks"
        }
      }
    },
    "messaging.provider_ingress.v1": {
      "kind": "messaging.provider_ingress.v1",
      "version": "0.4.36",
      "inline": {
        "capabilities": {
          "content_types": [
            "application/json"
          ],
          "supports_webhook_validation": true
        },
        "component_ref": "messaging-ingress-slack",
        "export": "handle-webhook",
        "world": "greentic:messaging-ingress-slack/messaging-ingress-slack@0.0.1"
      }
    }
  },
  "flows": [
    {
      "id": "setup_default",
      "file": "flows/setup_default.ygtc",
      "tags": [
        "default"
      ],
      "entrypoints": [
        "setup"
      ]
    },
    {
      "id": "requirements",
      "file": "flows/requirements.ygtc",
      "tags": [
        "default"
      ],
      "entrypoints": [
        "requirements"
      ]
    }
  ],
  "kind": "application",
  "messaging": {
    "adapters": [
      {
        "component": "messaging-ingress-slack",
        "kind": "ingress",
        "name": "messaging.slack.ingress"
      },
      {
        "component": "messaging-provider-slack",
        "kind": "egress",
        "name": "messaging.slack.api"
      }
    ]
  },
  "name": "messaging-slack",
  "publisher": "Greentic",
  "secret_requirements": [
    {
      "name": "SLACK_BOT_TOKEN",
      "scope": "tenant",
      "description": "Slack bot token used for chat.postMessage calls."
    },
    {
      "name": "SLACK_SIGNING_SECRET",
      "scope": "tenant",
      "description": "Slack signing secret (optional for future webhook validation)."
    }
  ],
  "version": "0.4.36"
}
